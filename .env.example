# Copy this file to .env and override values for your local environment.
# .env is gitignored — never commit real credentials.

# MySQL container (docker-compose.yml)
MYSQL_DATABASE=payments
MYSQL_USER=payments
MYSQL_PASSWORD=payments
MYSQL_ROOT_PASSWORD=root

# Spring Boot DataSource (application.yml)
# Export these in your shell before `./gradlew bootRun` if you want to override.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=payments
DB_USERNAME=payments
DB_PASSWORD=payments

# Spring Data Redis
REDIS_HOST=localhost
REDIS_PORT=6379
