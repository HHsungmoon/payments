# Copy this file to .env and override values for your local environment.
# .env is gitignored — never commit real credentials.

# ── MySQL container (docker-compose.yml) ──────────────
MYSQL_DATABASE=payments
MYSQL_USER=payments
MYSQL_PASSWORD=payments
MYSQL_ROOT_PASSWORD=root

# ── Spring Boot DataSource (application.yml) ──────────
# docker compose 환경에선 compose가 mysql 호스트명을 자동 주입함.
# 로컬 `./gradlew bootRun` 직접 실행 시에만 override 용도.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=payments
DB_USERNAME=payments
DB_PASSWORD=payments

# ── Spring Data Redis ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Mock PG (docker/mock-pg) ──────────────────────────
# 평소 0 으로 두고, 장애 시나리오 시험 시에만 키움.
MOCK_PG_LATENCY_MS=100    # 응답 지연 (ms)
MOCK_PG_FAIL_RATE=0       # 0~1 실패율 — Circuit Breaker 시험용
MOCK_PG_TIMEOUT_RATE=0    # 0~1 무응답율 — Timeout 시험용
